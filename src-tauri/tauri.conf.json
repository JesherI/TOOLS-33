{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tools-33",
  "version": "0.1.8",
  "identifier": "com.jeshe.tools-33",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "tools-33",
        "width": 1200,
        "height": 800,
        "minWidth": 400,
        "minHeight": 300,
        "decorations": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://raw.githubusercontent.com/JesherI/TOOLS-33/main/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../scripts/**/*",
      "bundled/**/*"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "installerHooks": "./installer.nsh"
      }
    }
  }
}
